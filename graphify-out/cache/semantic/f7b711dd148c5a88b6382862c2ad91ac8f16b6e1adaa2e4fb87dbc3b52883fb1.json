{"nodes": [{"id": "wiki_code_turbopack_css_filewatcher_miss", "label": "Turbopack CSS file-watch miss on programmatic write", "file_type": "rationale", "source_file": "wiki/code/turbopack-css-filewatcher-miss.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Turbopack watches files via the OS file notification API (kqueue on macOS); programmatic writes sometimes don't emit a notification event, or the event fires before the write is fully flushed, leaving the watcher unaware of the change. `touch app/globals.css` updates mtime and reliably triggers reprocessing."}], "edges": [{"source": "wiki_code_turbopack_css_filewatcher_miss", "target": "wiki_concepts_wiki_gotchas_lack_code_side_back_references", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "wiki/code/turbopack-css-filewatcher-miss.md", "source_location": null, "weight": 1.0}, {"source": "wiki_code_turbopack_css_filewatcher_miss", "target": "app_globals", "relation": "references", "confidence": "AMBIGUOUS", "confidence_score": 0.2, "source_file": "wiki/code/turbopack-css-filewatcher-miss.md", "source_location": null, "weight": 1.0}, {"source": "wiki_code_turbopack_css_filewatcher_miss", "target": "wiki_platforms_next_js_16_turbopack_root_confusion", "relation": "references", "confidence": "AMBIGUOUS", "confidence_score": 0.2, "source_file": "wiki/code/turbopack-css-filewatcher-miss.md", "source_location": null, "weight": 1.0}, {"source": "wiki_code_turbopack_css_filewatcher_miss", "target": "wiki_platforms_windows_git_worktree_remove_fails_due_to_own_shell_cwd", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "wiki/code/turbopack-css-filewatcher-miss.md", "source_location": null, "weight": 1.0}], "hyperedges": []}