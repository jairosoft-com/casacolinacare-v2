# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE
*.swp
*.swo
*~
.cursor/

# claude / agent runtime
/logs/
**/logs/
**/.claude/data/
.claude/worktrees/

# cache
.thumbnail

# playwright test runner output
/test-results/
/playwright-report/
/blob-report/

# playwright browser install / local cache
/.playwright/
/playwright/.cache/

# browser automation session snapshots (playwright-cli / playwright-mcp)
/.playwright-cli/
/.playwright-mcp/

# ad-hoc screenshots (playwright-cli, playwright test runner, manual captures)
/screenshots/
/*.png

# Playwright
node_modules/
/playwright/.auth/
